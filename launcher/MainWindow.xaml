<Window x:Class="SeapowerMultiplayer.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Sea Power Four Player"
        WindowStyle="None"
        WindowState="Normal"
        WindowStartupLocation="Manual"
        Left="0"
        Top="0"
        ResizeMode="NoResize"
        Background="#020609">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <LinearGradientBrush x:Key="CinemaLeft" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#E6000509" Offset="0"/>
            <GradientStop Color="#9C000509" Offset=".34"/>
            <GradientStop Color="#14000509" Offset=".72"/>
            <GradientStop Color="#00000509" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CinemaBottom" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00000509" Offset=".32"/>
            <GradientStop Color="#54000509" Offset=".67"/>
            <GradientStop Color="#F0000509" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DrawerBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FA071016" Offset="0"/>
            <GradientStop Color="#F40C1820" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Foreground" Value="#E8F2F7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,9"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#251D3542"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#46315160"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LaunchButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F3FBFE"/>
            <Setter Property="Background" Value="#E008171E"/>
            <Setter Property="BorderBrush" Value="#58D9F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,13"/>
            <Setter Property="MinWidth" Value="218"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root">
                            <Border x:Name="Glow"
                                    Margin="-3"
                                    BorderBrush="#4EDCFF"
                                    BorderThickness="1"
                                    Opacity=".32">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22"
                                                      ShadowDepth="0"
                                                      Opacity=".68"
                                                      Color="#42D9FF"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="Frame"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <Grid>
                                    <Border Width="4"
                                            HorizontalAlignment="Left"
                                            Background="#65E2FF"/>
                                    <Border Height="1"
                                            VerticalAlignment="Top"
                                            Margin="4,0,0,0"
                                            Background="#B8F3FF"/>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LaunchArrow"
                                               Text="›"
                                               Foreground="#65E2FF"
                                               FontSize="25"
                                               FontWeight="Light"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,17,2">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="ArrowShift"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Frame" Property="Background" Value="#EC0E2530"/>
                                <Setter TargetName="Glow" Property="Opacity" Value=".9"/>
                                <Setter TargetName="LaunchArrow" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value=".72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Frame" Property="Background" Value="#17242A"/>
                                <Setter TargetName="Frame" Property="BorderBrush" Value="#314650"/>
                                <Setter TargetName="Glow" Property="Opacity" Value="0"/>
                                <Setter TargetName="LaunchArrow" Property="Foreground" Value="#536771"/>
                                <Setter Property="Foreground" Value="#71838C"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ArrowShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="6"
                                                         Duration="0:0:0.16"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ArrowShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Background" Value="#17152720"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="TransportButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="LobbyListItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#EAF4F7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#17313D"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OperationRow"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="16,15">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OperationRow" Property="Background" Value="#10242D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OperationRow" Property="Background" Value="#173743"/>
                                <Setter TargetName="OperationRow" Property="BorderBrush" Value="#66DFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DrawerSectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6F8D9D"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,9"/>
        </Style>

        <Style x:Key="Hairline" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#233845"/>
            <Setter Property="Margin" Value="0,22,0,22"/>
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="4,0">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3"
                                                        Background="#75DFFF"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3"
                                                        Background="#40515A"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="13" Height="13">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#EFFBFF"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- A still remains underneath while Windows opens the embedded Steam trailer. -->
        <Image x:Name="BrollImage"
               Source="/Assets/Broll/frame-000.jpg"
               Stretch="UniformToFill"/>
        <MediaElement x:Name="BattleVideo"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Stretch="UniformToFill"
                      IsMuted="True"
                      ScrubbingEnabled="False"
                      MediaOpened="BattleVideo_MediaOpened"
                      MediaEnded="BattleVideo_MediaEnded"
                      MediaFailed="BattleVideo_MediaFailed"/>

        <Rectangle Fill="{StaticResource CinemaLeft}"/>
        <Rectangle Fill="{StaticResource CinemaBottom}"/>
        <Border Height="1"
                VerticalAlignment="Top"
                Background="#4CCFEA"
                Opacity=".16"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             From="90"
                                             To="1010"
                                             Duration="0:0:8"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <!-- Quiet top chrome. -->
        <Grid Height="68"
              VerticalAlignment="Top"
              Margin="28,0,18,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="27"
                        Height="27"
                        CornerRadius="14"
                        Background="#E7F8FF">
                    <TextBlock Text="4"
                               Foreground="#061117"
                               FontWeight="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="SEA POWER"
                           Foreground="#F5FAFC"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="11,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" / FOUR PLAYER"
                           Foreground="#7394A4"
                           FontSize="11"
                           Margin="4,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtVersion"
                           Foreground="#58717E"
                           FontSize="9"
                           Margin="9,1,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource ChromeButton}"
                        Content="PUBLIC LOBBIES"
                        Margin="0,0,5,0"
                        Click="BtnLobbies_Click"/>
                <Button Style="{StaticResource ChromeButton}"
                        Content="SETTINGS"
                        Margin="0,0,5,0"
                        Click="BtnSettings_Click"/>
                <Button Style="{StaticResource ChromeButton}"
                        Content="—"
                        Width="42"
                        Padding="0"
                        Click="BtnMinimize_Click"/>
                <Button Style="{StaticResource ChromeButton}"
                        Content="×"
                        Width="42"
                        Padding="0"
                        FontSize="17"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

        <!-- The home screen stays cinematic; configuration is hidden in the drawer. -->
        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="68,0,520,174">
            <TextBlock x:Name="TxtAnnouncement"
                       Text="JOIN THE SEAS // PUBLIC OPERATIONS ONLINE"
                       Foreground="#75DFFF"
                       FontSize="11"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>
            <TextBlock Text="COMMAND THE"
                       Foreground="#F7FBFD"
                       FontSize="62"
                       FontWeight="Light"
                       Margin="-2,12,0,0"/>
            <TextBlock Text="WHOLE FLEET."
                       Foreground="#F7FBFD"
                       FontSize="62"
                       FontWeight="Black"
                       Margin="-2,-12,0,0"/>
            <TextBlock Text="One host. Three friends. Red, Blue, and neutral traffic."
                       Foreground="#B3C4CC"
                       FontSize="14"
                       Margin="2,15,0,0"/>
        </StackPanel>

        <Border x:Name="PnlUpdate"
                Visibility="Collapsed"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="67,86,0,0"
                Background="#DAEEC26A"
                CornerRadius="19"
                Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtUpdateInfo"
                           Foreground="#081015"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnUpdate"
                        Style="{StaticResource ChromeButton}"
                        Foreground="#081015"
                        Content="UPDATE"
                        Margin="7,0,0,0"
                        Padding="10,4"
                        Click="BtnUpdate_Click"/>
            </StackPanel>
        </Border>

        <!-- Launch controls float directly over the footage. -->
        <Grid VerticalAlignment="Bottom"
              Height="126"
              Margin="67,0,58,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnLaunch"
                    Style="{StaticResource LaunchButton}"
                    Height="62"
                    Width="270"
                    VerticalAlignment="Center"
                    IsEnabled="False"
                    Click="BtnLaunch_Click">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="LAUNCH SEA POWER"
                               Foreground="#F2FBFE"
                               FontSize="13"
                               FontWeight="Bold"/>
                    <TextBlock Text="TACTICAL SYSTEM READY"
                               Foreground="#5DBCD3"
                               FontSize="8"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot"
                             Width="7"
                             Height="7"
                             Fill="{StaticResource WarningOrange}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever"
                                                AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From=".42"
                                                         To="1"
                                                         Duration="0:0:1.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock x:Name="TxtInstallStatus"
                               Text="Scanning"
                               Foreground="#E8F1F5"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button x:Name="BtnInstall"
                            Style="{StaticResource ChromeButton}"
                            Content="INSTALL"
                            Foreground="#93ADBA"
                            Padding="11,5"
                            Margin="5,0,0,0"
                            Click="BtnInstall_Click"/>
                </StackPanel>
                <TextBlock x:Name="TxtStatus"
                           Text="Ready"
                           Foreground="#78909C"
                           FontSize="10"
                           Margin="15,6,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Compact player with persistent volume and mute. -->
            <Border Grid.Column="3"
                    Width="510"
                    Height="74"
                    VerticalAlignment="Center"
                    Background="#CC081116"
                    CornerRadius="4"
                    Padding="23,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="142"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="118"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTrackTitle"
                                   Text="Playlist"
                                   Foreground="#F2F8FA"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtTrackArtist"
                                   Text="Launcher music"
                                   Foreground="#68818D"
                                   FontSize="9"
                                   Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnPreviousTrack"
                                Style="{StaticResource TransportButton}"
                                Content="‹"
                                ToolTip="Previous song"
                                Click="BtnPreviousTrack_Click"/>
                        <Button x:Name="BtnPlayPause"
                                Style="{StaticResource TransportButton}"
                                Content="II"
                                ToolTip="Play or pause"
                                Click="BtnPlayPause_Click"/>
                        <Button x:Name="BtnNextTrack"
                                Style="{StaticResource TransportButton}"
                                Content="›"
                                ToolTip="Next song"
                                Click="BtnNextTrack_Click"/>
                    </StackPanel>
                    <Slider x:Name="VolumeSlider"
                            Grid.Column="3"
                            Style="{StaticResource VolumeSliderStyle}"
                            Minimum="0"
                            Maximum="1"
                            SmallChange=".02"
                            LargeChange=".1"
                            VerticalAlignment="Center"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                    <Button x:Name="BtnMute"
                            Grid.Column="4"
                            Style="{StaticResource ChromeButton}"
                            Content="MUTE"
                            Padding="11,7"
                            Margin="7,0,0,0"
                            VerticalAlignment="Center"
                            Click="BtnMute_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- FiveM-style public operations browser. -->
        <Border x:Name="LobbyScrim"
                Visibility="Collapsed"
                Background="#3D000000"
                MouseLeftButtonDown="LobbyScrim_MouseLeftButtonDown"/>

        <Border x:Name="LobbyBrowser"
                Width="780"
                HorizontalAlignment="Left"
                Visibility="Collapsed"
                Opacity="0"
                Padding="42,30,76,30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FE02080B" Offset="0"/>
                    <GradientStop Color="#F8071116" Offset=".82"/>
                    <GradientStop Color="#B8071116" Offset=".93"/>
                    <GradientStop Color="#00071116" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.RenderTransform>
                <TranslateTransform X="-780"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="PUBLIC OPERATIONS"
                                   Foreground="#F4FAFC"
                                   FontSize="29"
                                   FontWeight="Light"/>
                        <TextBlock Text="STEAM MATCHMAKING // RAILWAY DISCOVERY LINK"
                                   Foreground="#62D9FF"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="1,6,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButton}"
                            Content="CLOSE"
                            VerticalAlignment="Top"
                            Click="BtnCloseLobbies_Click"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,29,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                   Text="OPERATION NAME"/>
                        <TextBox x:Name="TxtPublicLobbyName"
                                 Text="Open Fleet"
                                 MaxLength="64"/>
                    </StackPanel>
                    <Button x:Name="BtnCreatePublicLobby"
                            Grid.Column="2"
                            Style="{StaticResource LaunchButton}"
                            Content="CREATE PUBLIC LOBBY"
                            MinWidth="228"
                            Padding="20,13"
                            VerticalAlignment="Bottom"
                            Click="BtnCreatePublicLobby_Click"/>
                </Grid>

                <Border Grid.Row="2"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Background="Transparent">
                    <Grid>
                        <ListBox x:Name="LobbyList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource LobbyListItem}"
                                 SelectionChanged="LobbyList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="82"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding LobbyName}"
                                                       Foreground="#F2F8FA"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Foreground="#66818D"
                                                       FontSize="10"
                                                       Margin="0,5,0,0">
                                                <Run Text="HOST "/>
                                                <Run Text="{Binding HostName}"/>
                                                <Run Text="  //  "/>
                                                <Run Text="{Binding Scenario}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Crew}"
                                                   Foreground="#E7F3F7"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Mode}"
                                                   Foreground="#62D9FF"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Side}"
                                                   Foreground="#8DA6B1"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                        <Button Grid.Column="4"
                                                Style="{StaticResource OutlineButton}"
                                                Content="JOIN"
                                                Padding="14,8"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                CommandParameter="{Binding}"
                                                Click="BtnJoinLobbyRow_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel x:Name="LobbyEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Grid Width="86" Height="86" Margin="0,0,0,17">
                                <Ellipse Stroke="#21404B" StrokeThickness="1"/>
                                <Ellipse Width="50" Height="50" Stroke="#17333D" StrokeThickness="1"/>
                                <Line X1="43" Y1="0" X2="43" Y2="86" Stroke="#17333D"/>
                                <Line X1="0" Y1="43" X2="86" Y2="43" Stroke="#17333D"/>
                                <Ellipse Width="6" Height="6" Fill="#55D9F5"/>
                            </Grid>
                            <TextBlock x:Name="TxtLobbyEmptyTitle"
                                       Text="SCANNING PUBLIC OPERATIONS"
                                       Foreground="#A9BEC7"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtLobbyEmptyDetail"
                                       Text="Contacting the lobby directory..."
                                       Foreground="#58727E"
                                       FontSize="10"
                                       Margin="0,7,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtLobbyServiceStatus"
                               Text="DIRECTORY STANDBY"
                               Foreground="#6D8792"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource OutlineButton}"
                            Content="REFRESH"
                            Click="BtnRefreshLobbies_Click"/>
                    <Button x:Name="BtnJoinPublicLobby"
                            Grid.Column="3"
                            Style="{StaticResource LaunchButton}"
                            Content="JOIN SELECTED"
                            MinWidth="165"
                            Padding="20,12"
                            IsEnabled="False"
                            Click="BtnJoinPublicLobby_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Clicking outside dismisses the settings drawer. -->
        <Border x:Name="SettingsScrim"
                Visibility="Collapsed"
                Background="#50000000"
                MouseLeftButtonDown="SettingsScrim_MouseLeftButtonDown"/>

        <Border x:Name="SettingsDrawer"
                Width="474"
                HorizontalAlignment="Right"
                Background="{StaticResource DrawerBrush}"
                Visibility="Collapsed"
                Opacity="0"
                Padding="38,27,42,34">
            <Border.RenderTransform>
                <TranslateTransform X="474"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="42"
                                  ShadowDepth="-8"
                                  Opacity=".65"
                                  Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="SETUP"
                                   Foreground="#F4F9FB"
                                   FontSize="30"
                                   FontWeight="Light"/>
                        <TextBlock Text="Saved automatically on this PC"
                                   Foreground="#6F8996"
                                   FontSize="10"
                                   Margin="1,5,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButton}"
                            Content="DONE"
                            VerticalAlignment="Top"
                            Click="BtnCloseSettings_Click"/>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,29,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                   Text="GAME LOCATION"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtGamePath" IsReadOnly="True"/>
                            <Button x:Name="BtnBrowse"
                                    Grid.Column="2"
                                    Style="{StaticResource OutlineButton}"
                                    Content="BROWSE"
                                    Padding="14,10"
                                    Click="BtnBrowse_Click"/>
                        </Grid>

                        <Border Style="{StaticResource Hairline}"/>

                        <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                   Text="PLAYER"/>
                        <TextBox x:Name="TxtPlayerName"/>

                        <Border Style="{StaticResource Hairline}"/>

                        <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                   Text="CONNECTION"/>
                        <Border Background="#0A1A21"
                                BorderBrush="#20414E"
                                BorderThickness="1,0,0,0"
                                Padding="11,8"
                                Margin="0,0,0,13">
                            <TextBlock Text="RECOMMENDED  STEAM · HOST SIDE BLUE · 20/10 HZ"
                                       Foreground="#6FCFEF"
                                       FontSize="9"
                                       FontWeight="Bold"/>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbSteam"
                                         Content="Steam"
                                         GroupName="Transport"
                                         IsChecked="True"
                                         Margin="0,0,28,0"
                                         Checked="Transport_Changed"/>
                            <RadioButton x:Name="RbDirectIP"
                                         Content="Direct IP"
                                         GroupName="Transport"
                                         Checked="Transport_Changed"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,13,0,0">
                            <RadioButton x:Name="RbHost"
                                         Content="Host"
                                         GroupName="Role"
                                         IsChecked="True"
                                         Margin="0,0,28,0"
                                         Checked="Role_Changed"/>
                            <RadioButton x:Name="RbClient"
                                         Content="Join"
                                         GroupName="Role"
                                         Checked="Role_Changed"/>
                        </StackPanel>

                        <StackPanel x:Name="PnlHostTeam" Margin="0,19,0,0">
                            <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                       Text="HOST SIDE"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbHostBlue"
                                             Content="Blue"
                                             GroupName="HostTeam"
                                             IsChecked="True"
                                             Margin="0,0,28,0"/>
                                <RadioButton x:Name="RbHostRed"
                                             Content="Red"
                                             GroupName="HostTeam"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid x:Name="PnlDirectIP"
                              Visibility="Collapsed"
                              Margin="0,19,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="106"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                           Text="HOST IP"/>
                                <TextBox x:Name="TxtHostIP"
                                         Text="0.0.0.0"
                                         IsEnabled="False"
                                         TextChanged="TxtHostIP_TextChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                           Text="PORT"/>
                                <TextBox x:Name="TxtPort"
                                         Text="7777"
                                         TextChanged="TxtPort_TextChanged"/>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource Hairline}"/>

                        <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                   Text="SESSION"/>
                        <WrapPanel>
                            <CheckBox x:Name="ChkAutoConnect"
                                      Content="Auto-connect"
                                      Margin="0,0,22,7"/>
                            <CheckBox x:Name="ChkPvP"
                                      Content="PvP"
                                      Margin="0,0,22,7"/>
                            <CheckBox x:Name="ChkTimeVote"
                                      Content="Time voting"
                                      Margin="0,0,22,7"/>
                        </WrapPanel>

                        <Grid Margin="0,17,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                           Text="MISSILE RATE"/>
                                <TextBox x:Name="TxtMissileHz"
                                         Text="20"
                                         TextChanged="TxtHz_TextChanged"/>
                                <Slider x:Name="MissileRateSlider"
                                        Style="{StaticResource VolumeSliderStyle}"
                                        Minimum="1"
                                        Maximum="60"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Margin="0,6,0,0"
                                        ValueChanged="RateSlider_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource DrawerSectionLabel}"
                                           Text="UNIT RATE"/>
                                <TextBox x:Name="TxtUnitHz"
                                         Text="10"
                                         TextChanged="TxtHz_TextChanged"/>
                                <Slider x:Name="UnitRateSlider"
                                        Style="{StaticResource VolumeSliderStyle}"
                                        Minimum="1"
                                        Maximum="60"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Margin="0,6,0,0"
                                        ValueChanged="RateSlider_ValueChanged"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="20 Hz missiles and 10 Hz units are the tested stability profile."
                                   Foreground="#607C89"
                                   FontSize="9"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>

                        <Border Style="{StaticResource Hairline}"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnFeedback"
                                    Style="{StaticResource OutlineButton}"
                                    Content="FEEDBACK"
                                    Margin="0,0,9,0"
                                    Click="BtnFeedback_Click"/>
                            <Button x:Name="BtnDiscord"
                                    Style="{StaticResource OutlineButton}"
                                    Content="DISCORD"
                                    Click="BtnDiscord_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Aegis-inspired cold boot sequence. -->
        <Grid x:Name="BootOverlay"
              Background="#FF010608"
              Panel.ZIndex="30">
            <Rectangle Opacity=".18">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,1,5"
                                  ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#17627A">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,1,1"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Grid Margin="70,54">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="AEGIS COMBAT INFORMATION CENTER"
                                   Foreground="#7DE3FF"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                        <TextBlock Text="SEA POWER // FOUR PLAYER NETWORK"
                                   Foreground="#547985"
                                   FontSize="9"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="SYSTEM START"
                               Foreground="#52717C"
                               FontFamily="Consolas"
                               FontSize="10"/>
                </Grid>
                <Grid Grid.Row="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="390"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Width="310" Height="310">
                        <Ellipse Stroke="#173A47" StrokeThickness="1"/>
                        <Ellipse Width="220" Height="220" Stroke="#173A47" StrokeThickness="1"/>
                        <Ellipse Width="130" Height="130" Stroke="#173A47" StrokeThickness="1"/>
                        <Line X1="155" Y1="0" X2="155" Y2="310" Stroke="#153440"/>
                        <Line X1="0" Y1="155" X2="310" Y2="155" Stroke="#153440"/>
                        <Polygon Points="155,155 155,8 173,155"
                                 Fill="#2D7EA0"
                                 Opacity=".35"
                                 RenderTransformOrigin=".5,.5">
                            <Polygon.RenderTransform>
                                <RotateTransform x:Name="BootSweepTransform"
                                                 CenterX="155"
                                                 CenterY="155"/>
                            </Polygon.RenderTransform>
                        </Polygon>
                        <TextBlock Text="SPY-1 ARRAY"
                                   Foreground="#65D9F9"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel Grid.Column="2"
                                Width="610"
                                HorizontalAlignment="Left">
                        <TextBlock Text="TACTICAL SYSTEM INITIALIZATION"
                                   Foreground="#EEF9FC"
                                   FontSize="31"
                                   FontWeight="Light"/>
                        <TextBlock x:Name="TxtBootLine"
                                   Text="ESTABLISHING COMMAND BUS..."
                                   Foreground="#65D9F9"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="1,24,0,0"/>
                        <TextBlock x:Name="TxtBootLog"
                                   Foreground="#557783"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   LineHeight="20"
                                   Margin="1,16,0,0"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtBootPercent"
                               Text="000%"
                               Foreground="#668792"
                               FontFamily="Consolas"
                               FontSize="10"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Background="#10252D">
                        <Border x:Name="BootProgress"
                                Width="0"
                                Background="#65D9F9"
                                HorizontalAlignment="Left"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
